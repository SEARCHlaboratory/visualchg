        },
        "target": "blade_velocity",
        "weight": 1.0,
        "via": "def Rcheck_blade_stopped(is_clearing, is_returning, **kw):\n    \"Checks if the blade is stopped.\"\n    return not is_clearing and not is_returning\n",
        "index_via": "def Rsame(*args, **kwargs):\n    \"\"\"Returns true if all arguments are equivalent.\"\"\"\n    args = set(extend(args, kwargs))\n    if len(args) == 0:  # Trivial case\n        return True\n    return len(args) == 1\n",
        "disposable": [
          "is_clearing",
          "is_returning"
        ]
      },
      {
        "label": "(blad,time,blad)->blade_po",
        "rel": "def Reulerian_integration(rate: float, step: float, initial: float, \n                          *ar, **kw)-> float:\n    \"\"\"Performs a first-order Eulerian integration.\"\"\"\n    out = initial + rate * step\n    return out\n",
        "source_nodes": {
          "rate": "blade_velocity",
          "step": "timestep",
          "initial": "blade_position"
        },
        "target": "blade_position",
        "weight": 1.0,
        "index_via": "def Ridx_offset_rate(rate, initial, **kw):\n    \"Checks if the rate is equal to the initial value plus one.\"\n    return rate == initial + 1\n",
        "disposable": [
          "rate",
          "initial"
        ]
      },
      {
        "label": "(blad)->blade_re",
        "rel": "def Rcalc_blade_returned(rel_position: float, *ar, **kw)-> bool:\n    \"\"\"Returns true if the blade is in its home position.\"\"\"\n    returned = rel_position <= 0.\n    return returned\n",
        "source_nodes": {
          "rel_position": "blade_relative_position"
        },
        "target": "blade_returned",
        "weight": 1.0
      },
      {
        "label": "(blad)->blade_at",
        "rel": "def Rcyclecounter(*args, **kwargs):\n    args, kwargs = get_keyword_arguments(args, kwargs, identifier)\n    return kwargs[identifier] >= val\n",
        "source_nodes": {
          "rel_pos": "blade_relative_position"
        },
        "target": "blade_at_end",
        "weight": 1.0
      },
      {
        "label": "(blad,blad,blad)->blade_re",
        "rel": "def Rcalc_blade_rel_position(home: float, end: float, position: float,\n                             *ar, **kw)-> bool:\n    \"\"\"Returns proportion of distance blade is from home and end positions.\"\"\"\n    prop = (position - home) / (end - home)\n    return prop\n",
        "source_nodes": {
          "home": "blade_home_position",
          "end": "blade_end_position",
          "position": "blade_position"
        },
        "target": "blade_relative_position",
        "weight": 1.0
      },
      {
        "label": "(blad,blad,blad)->leveling",
        "rel": "def Rcalc_leveling_time(home: float, end: float, speed: float,\n                        *ar, **kw)-> float:\n    \"\"\"Calculates nominal time for leveling process.\"\"\"\n    distance = abs(home - end) * 2\n    min_time = distance / speed\n    adj_time = min_time * 1.2\n    return adj_time\n",
        "source_nodes": {
          "home": "blade_home_position",
          "end": "blade_end_position",
          "speed": "blade_max_velocity"
        },
        "target": "leveling_time",
        "weight": 1.0
      },
      {
        "label": "check_blade_is_clearing",
        "rel": "def Rcalc_blade_clearing_status(leveling: bool, returning: bool, rel_pos: float,\n                                prev_status: bool):\n    \"\"\"Calculates if the blade is clearing.\"\"\"\n    if any([not leveling, returning]):\n        return False\n    if rel_pos >= 1.:\n        return False\n    if rel_pos <= 0.:\n        return True\n    return prev_status\n",
        "source_nodes": {
          "leveling": "blade_is_leveling",
          "returning": "blade_is_returning",
          "rel_pos": "blade_relative_position",
          "prev_status": "blade_is_clearing"
        },
