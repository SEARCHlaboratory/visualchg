      {
        "label": "(blad,blad,blad)->blade_ve",
        "rel": "def Rnegate_speed(speed, **kw):\n    \"Negates the speed argument.\"\n    return -speed\n",
        "source_nodes": {
          "is_clearing": "blade_is_clearing",
          "is_returning": "blade_is_returning",
          "speed": "blade_max_velocity"
        },
        "target": "blade_velocity",
        "weight": 1.0,
        "via": "def Rcheck_blade_is_clearing(is_clearing, is_returning, **kw):\n    \"Checks if the blade is clearing.\"\n    return is_clearing and not is_returning\n",
        "index_via": "def Ridx_blade_moving(is_clearing, is_returning, **kw):\n    \"Checks if the blade is clearing for indexing.\"\n    return R.Rsame(is_clearing, is_returning)\n",
        "disposable": [
          "is_clearing",
          "is_returning"
        ]
      },
      {
        "label": "(blad,blad,blad)->blade_ve#1",
        "rel": "def Requal(*args, **kwargs):\n    args, kwargs = get_keyword_arguments(args, kwargs, identifier)\n    return kwargs[identifier]\n",
        "source_nodes": {
          "is_clearing": "blade_is_clearing",
