        "rel": "def Rcalc_fusing_start_time(leveled: bool, progress: float, time: float,\n                            prev_start: float, *ar, **kw)-> bool:\n    \"\"\"Returns the time that fusion began for the current layer.\"\"\"\n    if all([leveled, progress < 99.999]):\n        return time\n    return prev_start\n",
