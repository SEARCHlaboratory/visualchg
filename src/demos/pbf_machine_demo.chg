      {
        "label": "(laye,leve)->build_ti",
        "rel": "def Rcalc_build_time(scan_times: list, leveling_time: float,\n                     *ar, **kw)-> float:\n    \"\"\"Calculates the total time to build the part.\"\"\"\n    build_time = sum(scan_times) + leveling_time * len(scan_times)\n    return build_time\n",
