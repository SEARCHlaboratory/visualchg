        "weight": 1.0,
        "index_via": "def Rsame(*args, **kwargs):\n    \"\"\"Returns true if all arguments are equivalent.\"\"\"\n    args = set(extend(args, kwargs))\n    if len(args) == 0:  # Trivial case\n        return True\n    return len(args) == 1\n",
        "index_offset": 1,
        "disposable": [
          "leveling",
          "returning",
          "prev_status",
          "rel_pos"
        ]
      },
      {
        "label": "check_blade_is_returning",
        "rel": "def Rcalc_blade_returning_status(clearing: bool, rel_pos: float,\n                                prev_status: bool):\n    \"\"\"Calculates if the blade is returning.\"\"\"\n    if clearing:\n        return False\n    if rel_pos <= 0.:\n        return False\n    if rel_pos >= 1.:\n        return True\n    return prev_status\n",
        "source_nodes": {
          "clearing": "blade_is_clearing",
