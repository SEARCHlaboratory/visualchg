        "via": "def Rcheck_blade_is_returning(is_clearing, is_returning, **kw):\n    \"Checks if the blade is returning.\"\n    return not is_clearing and is_returning\n",
        "index_via": "def Ridx_blade_moving(is_clearing, is_returning, **kw):\n    \"Checks if the blade is clearing for indexing.\"\n    return R.Rsame(is_clearing, is_returning)\n",
        "disposable": [
          "is_clearing",
          "is_returning"
        ]
      },
      {
        "label": "check_blade_stopped",
        "rel": "def Rget_zero(*args, **kw):\n    \"Returns zero.\"\n    return 0.\n",
        "source_nodes": {
